.DS_Store
.dart_tool/
**/.dart_tool/

.packages
.pub/

build/
ios/*


.idea/
*.iml
pubspec.lock
.metadata
./android/
.flutter-plugins
android/*

flutter/wrapper/flutterw/__pycache__
.vscode/settings.json
flutter/wrapper/.idea/flutterw_sdk.path
out.dill.txt

# Common OS / editor / generated junk. (doc/api/ is generated dartdoc only --
# the doc/*.md sources are tracked.)
Thumbs.db
*.log
.flutter-plugins-dependencies
pubspec_overrides.yaml
coverage/
doc/api/
.fvm/

# Local compiler artifacts.
*.dill
*.dill.txt
*.snapshot
*.snapshot.tmp
compiler/frontend_server/frontend_server_aot.dart.snapshot

# AOPD snapshots only need SDK package source files. Keep upstream test,
# benchmark, example, and doc assets out of git to reduce repo/analyzer load.
compiler/pkg/*/test/
compiler/pkg/*/testcases/
compiler/pkg/*/parser_testcases/
compiler/pkg/*/outline_extraction_testcases/
compiler/pkg/*/testing/
compiler/pkg/*/benchmark/
compiler/pkg/*/benchmarks/
compiler/pkg/*/example/
compiler/pkg/*/examples/
compiler/pkg/*/doc/
compiler/pkg/*/docs/
compiler/pkg/*/bin/
!compiler/pkg/vm/bin/
!compiler/pkg/vm/bin/dump_kernel.dart
compiler/pkg/*/tool/
compiler/pkg/*/web/
compiler/pkg/*/.dart_tool/
compiler/pkg/*/.gitignore
compiler/pkg/*/analysis_options*.yaml
compiler/pkg/*/OWNERS
compiler/pkg/*/PRESUBMIT.py
compiler/pkg/*/codereview.settings
compiler/pkg/*/testing.json
compiler/pkg/*/testing_with_lints.json
compiler/pkg/*/messages.status
compiler/pkg/*/presubmit_helper*.dart
compiler/pkg/*/error_recovery.yaml
